# ──────────────────────────────────────────────────────────────────────────────
# .env — Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Choose which LLM service to use:
#   groq   → FREE tier, fast inference (recommended for beginners)
LLM_PROVIDER=groq

# ─── Groq (FREE) ──────────────────────────────────────────────────────────────
# Get your FREE API key at: https://console.groq.com
# Then paste it below (no quotes needed)
GROQ_API_KEY=sk_oGwQiVuDDYh62uL9NxqCWGdyb3FYwMX81fvJEuRPHVmiGGwxtel7

# Free Groq models you can use (change anytime):
#   llama-3.3-70b-versatile   ← best quality (default)
#   llama-3.1-8b-instant      ← fastest
#   mixtral-8x7b-32768        ← good for long context
#   gemma2-9b-it              ← Google Gemma
GROQ_MODEL=llama-3.3-70b-versatile